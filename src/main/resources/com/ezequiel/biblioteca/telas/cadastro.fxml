                              <Insets top="20.0" />
                           </GridPane.margin>
                        </Label>
                        <Label fx:id="alertDate" alignment="CENTER" contentDisplay="CENTER" prefHeight="44.0" prefWidth="305.0" text="Insira uma data de nasciemento" GridPane.rowIndex="7">
                           <GridPane.margin>
                              <Insets top="20.0" />
                           </GridPane.margin>
                        </Label>
                        <Label fx:id="alertEmail" alignment="CENTER" contentDisplay="CENTER" prefHeight="44.0" prefWidth="305.0" text="Insira um Email" GridPane.rowIndex="7">
